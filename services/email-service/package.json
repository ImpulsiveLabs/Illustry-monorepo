{
  "name": "@impulsivelabs/illustry-email-service",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "clean": "rm -rf ./dist",
    "compile": "tsc -p tsconfig.json",
    "build:ts": "yarn clean && yarn compile",
    "start:dev": "yarn build:ts && node ./dist/index.js",
    "start:prod": "node ./dist/index.js",
    "lint": "echo 'No lint configured for email service'",
    "lint:fix": "echo 'No lint configured for email service'",
    "depcheck": "echo 'No depcheck configured for email service'",
    "test": "../../node_modules/.bin/jest --config jest.config.cjs --runInBand --coverage",
    "test:shard": "../../node_modules/.bin/jest --config jest.config.cjs --coverage --shard=${SHARD_INDEX:-1}/${SHARD_TOTAL:-1}"
  },
  "dependencies": {
    "dotenv": "16.3.1",
    "express": "4.21.2",
    "nodemailer": "8.0.6",
    "sanitize-html": "2.17.4",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.10.2",
    "@types/nodemailer": "8.0.0",
    "@types/sanitize-html": "2.16.1",
    "typescript": "5.5.4"
  }
}
