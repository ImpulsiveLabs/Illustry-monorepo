{
  "name": "@illustry/cli",
  "version": "1.0.0",
  "description": "Command line automation for Illustry local and server-backed workflows.",
  "license": "Apache-2.0",
  "author": "Vladimir Nitu",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "illustry": "dist/index.js"
  },
  "files": [
    "dist/**/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf ./dist",
    "build:ts": "yarn clean && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "lint:fix": "yarn lint",
    "test": "../../node_modules/.bin/jest --config jest.config.cjs --runInBand --coverage",
    "test:shard": "../../node_modules/.bin/jest --config jest.config.cjs --coverage --shard=${SHARD_INDEX:-1}/${SHARD_TOTAL:-1}"
  },
  "dependencies": {
    "@illustry/core": "1.0.0",
    "commander": "11.1.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.12",
    "@types/node": "20.10.2",
    "jest": "29.7.0",
    "ts-jest": "29.1.1",
    "typescript": "5.5.4"
  }
}
