MONGO_URL=mongodb://localhost:27017/illustry
MONGO_TEST_URL=mongodb://localhost:27017/illustrytest
MONGO_USER=root
MONGO_PASSWORD=rootPass
ILLUSTRY_PORT=8000

# Allowed web origins (comma-separated)
CORS_ORIGIN_ALLOWLIST=http://localhost:3000,http://127.0.0.1:3000,http://localhost:4321,http://127.0.0.1:4321

# Auth cookie/session configuration
AUTH_SESSION_COOKIE_NAME=illustry_sid
AUTH_CSRF_COOKIE_NAME=illustry_csrf
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_MINUTES=1440
AUTH_EMAIL_VERIFICATION_TTL_MINUTES=60
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_APP_BASE_URL=http://localhost:3000

# Argon2id hardening
AUTH_ARGON2_MEMORY_COST=19456
AUTH_ARGON2_TIME_COST=2
AUTH_ARGON2_PARALLELISM=1

# Rate limits
GLOBAL_RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=25
AUTH_SENSITIVE_RATE_LIMIT_MAX=8

# External email service integration
EMAIL_SERVICE_URL=http://localhost:7100
EMAIL_SERVICE_API_KEY=change-me

# Google OAuth (optional, required only if Google login is enabled)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:7001/api/auth/google/callback
GOOGLE_OAUTH_SCOPE=openid email profile
