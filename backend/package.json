{
  "name": "@impulsivelabs/illustry-server",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "author": "Vladimir Nitu",
  "main": "dist/app-cli.js",
  "scripts": {
    "clean": "rm -rf ./dist",
    "compile": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "depcheck": "knip --workspace @impulsivelabs/illustry-server",
    "build:ts": " yarn clean && yarn compile",
    "start:dev": "yarn build:ts && node ./dist/app-cli.js",
    "start:prod": "node ./build-dist/illustry.js",
    "cleanup:shares": "node ./scripts/clear-share-records.cjs",
    "seed:test-users": "node ./scripts/create-test-users.cjs",
    "provision:test-users": "node ./scripts/create-test-users.cjs",
    "latency:api": "node ./scripts/check-api-latency.cjs",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --detectOpenHandles --runInBand",
    "test:shard": "NODE_OPTIONS=--experimental-vm-modules jest --detectOpenHandles --runInBand --shard=${SHARD_INDEX:-1}/${SHARD_TOTAL:-1}",
    "e2e:api": "playwright test -c playwright.api.config.ts",
    "e2e:api:shard": "playwright test -c playwright.api.config.ts --shard=${SHARD_INDEX:-1}/${SHARD_TOTAL:-1}",
    "webpack": "webpack --config webpack.config.js"
  },
  "dependencies": {
    "@illustry/types": "^1.0.2",
    "argon2": "0.44.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "docx": "9.6.1",
    "dotenv": "16.3.1",
    "echarts": "6.1.0",
    "exceljs": "4.4.0",
    "express": "4.21.2",
    "express-rate-limit": "7.5.1",
    "helmet": "8.1.0",
    "jszip": "3.10.1",
    "mongoose": "8.24.0",
    "multer": "2.2.0",
    "pdf-lib": "1.17.1",
    "pptxgenjs": "4.0.1",
    "redis": "5.12.1",
    "sharp": "0.33.5",
    "validator": "13.15.26",
    "ws": "8.21.0",
    "xml2js": "0.6.2"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.17",
    "@types/exceljs": "0.5.3",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/multer": "2.2.0",
    "@types/node": "20.10.2",
    "@types/validator": "13.11.6",
    "@types/ws": "8.18.1",
    "@types/xml2js": "0.4.14",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "eslint": "9.39.4",
    "jest": "29.7.0",
    "jest-junit": "17.0.0",
    "lint-staged": "16.3.2",
    "shebang-loader": "0.0.1",
    "terser-webpack-plugin": "5.3.14",
    "ts-jest": "29.1.1",
    "ts-loader": "9.5.1",
    "typescript": "5.5.4",
    "webpack": "5.105.4",
    "webpack-cli": "5.1.4",
    "zod": "3.22.4",
    "zod-error": "1.5.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "git add"
    ]
  },
  "jest": {
    "collectCoverage": true,
    "roots": [
      "<rootDir>/__tests__"
    ],
    "collectCoverageFrom": [
      "**/*.{js,ts}",
      "!coverage/**",
      "!**/node_modules/**",
      "!**/dist/**",
      "!**/src/app-cli.ts"
    ],
    "transform": {
      ".+\\.ts$": "ts-jest"
    },
    "moduleNameMapper": {
      "uuid$": "<rootDir>/__tests__/mocks/uuid.cjs"
    },
    "coverageReporters": [
      "text",
      "text-summary"
    ],
    "reporters": [
      "default"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 0,
        "functions": 0,
        "lines": 0,
        "statements": 0
      }
    },
    "testEnvironment": "node"
  }
}
