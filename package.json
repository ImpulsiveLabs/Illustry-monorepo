{
  "name": "illustry-monorepo",
  "version": "1.1.0",
  "repository": "https://github.com/mrVladimirN/Illustry-monorepo.git",
  "author": "mrVladimirN <vladimir.nitu.business@outlook.com>",
  "license": "MIT",
  "workspaces": [
    "backend",
    "frontend",
    "docs",
    "types",
    "services/*"
  ],
  "type": "module",
  "scripts": {
    "lint": "yarn workspaces foreach -A -pt run lint",
    "lint:fix": "yarn workspaces foreach -A -pt run lint:fix",
    "version": "echo \"standard-version removed; use external release tooling\"",
    "depcheck": "knip --dependencies --no-config-hints",
    "test": "yarn workspaces foreach -A -pt run test",
    "test:backend:shard": "yarn workspace @impulsivelabs/illustry-server test:shard",
    "test:frontend:shard": "yarn workspace @impulsivelabs/illustry-client test:shard",
    "test:types:shard": "yarn workspace @illustry/types test:shard",
    "test:email:shard": "yarn workspace @impulsivelabs/illustry-email-service test:shard",
    "e2e": "yarn workspace @impulsivelabs/illustry-client e2e",
    "e2e:shard": "yarn workspace @impulsivelabs/illustry-client e2e:shard",
    "e2e:api": "yarn workspace @impulsivelabs/illustry-server e2e:api",
    "e2e:api:shard": "yarn workspace @impulsivelabs/illustry-server e2e:api:shard",
    "e2e:coverage:shard": "yarn workspace @impulsivelabs/illustry-client e2e:coverage:shard",
    "e2e:coverage:report": "yarn workspace @impulsivelabs/illustry-client e2e:coverage:report",
    "e2e:coverage:check:only": "yarn workspace @impulsivelabs/illustry-client e2e:coverage:check:only",
    "latency:api": "yarn workspace @impulsivelabs/illustry-server latency:api",
    "prepare": "husky install",
    "postversion": "echo \"manual publish step required\"",
    "build:ts": "yarn workspaces foreach -A -pt run build:ts",
    "release": "yarn lint:fix && yarn version && git push --follow-tags origin main",
    "audit": "yarn npm audit --all --recursive --severity low --no-deprecations"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@commitlint/config-conventional": "20.4.3",
    "@commitlint/lint": "20.4.3",
    "@commitlint/load": "20.4.3",
    "@types/jest": "29.5.12",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "eslint": "9.39.4",
    "husky": "8.0.3",
    "jest": "29.7.0",
    "jest-junit": "17.0.0",
    "knip": "6.7.0",
    "ts-jest": "29.1.1",
    "typescript": "5.5.4"
  },
  "resolutions": {
    "@astrojs/check": "0.9.8",
    "@fast-csv/format": "5.0.5",
    "@fast-csv/parse": "5.0.5",
    "@babel/helpers": "7.28.6",
    "@babel/runtime": "7.28.6",
    "axios": "1.13.6",
    "basic-ftp": "5.2.0",
    "diff": "8.0.3",
    "fast-csv": "5.0.5",
    "form-data": "4.0.5",
    "brace-expansion@npm:^1.1.7": "1.1.13",
    "brace-expansion@npm:^2.0.1": "2.0.3",
    "brace-expansion@npm:^2.0.2": "2.0.3",
    "brace-expansion@npm:^5.0.2": "5.0.5",
    "cookie@npm:0.4.0": "0.7.2",
    "defu": "6.1.5",
    "fast-uri": "3.1.2",
    "fast-xml-parser": "5.7.1",
    "h3": "1.15.11",
    "ip-address": "10.2.0",
    "js-yaml": "4.1.1",
    "mdast-util-to-hast": "13.2.1",
    "micromatch": "4.0.8",
    "qs": "6.15.0",
    "rollup": "4.59.0",
    "path-to-regexp@npm:~0.1.12": "0.1.13",
    "path-to-regexp@npm:0.1.12": "0.1.13",
    "postcss": "8.5.10",
    "picomatch@npm:^2.0.4": "2.3.2",
    "picomatch@npm:^2.2.1": "2.3.2",
    "picomatch@npm:^2.2.3": "2.3.2",
    "picomatch@npm:^2.3.1": "2.3.2",
    "picomatch@npm:^4.0.2": "4.0.4",
    "picomatch@npm:^4.0.3": "4.0.4",
    "serialize-javascript": "7.0.5",
    "sucrase": "3.35.1",
    "systeminformation": "5.31.3",
    "tar": "7.5.11",
    "undici": "7.24.3",
    "devalue": "5.8.1",
    "flatted": "3.4.2",
    "tmp": "0.2.5",
    "smol-toml": "1.6.1",
    "vite": "8.0.10",
    "unzipper": "0.12.3",
    "yaml@npm:^1.10.0": "1.10.3",
    "yaml@npm:2.7.1": "2.8.3",
    "yaml@npm:^2.3.4": "2.8.3",
    "yaml@npm:^2.5.0": "2.8.3",
    "uuid@npm:^8.3.0": "14.0.0",
    "uuid@npm:^8.3.2": "14.0.0",
    "yaml-language-server": "1.22.0",
    "yaml@npm:^2.8.2": "2.8.3"
  },
  "jest": {
    "collectCoverage": true,
    "roots": [
      "backend/",
      "frontend/",
      "types/",
      "docs/"
    ],
    "collectCoverageFrom": [
      "**/*.{js,ts}",
      "!coverage/**",
      "!**/node_modules/**",
      "!**/dist/**",
      "!**/commitlint.config.js"
    ],
    "transform": {
      ".+\\.ts$": "ts-jest"
    },
    "coverageReporters": [
      "text",
      "text-summary"
    ],
    "reporters": [
      "default"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 0,
        "functions": 0,
        "lines": 0,
        "statements": 0
      }
    },
    "testEnvironment": "node"
  },
  "packageManager": "yarn@4.5.3",
  "knip": {
    "ignoreDependencies": [
      "@astrojs/check",
      "@babel/core",
      "@commitlint/config-conventional",
      "@commitlint/lint",
      "@commitlint/load",
      "@types/echarts",
      "@types/exceljs",
      "@typescript-eslint/eslint-plugin",
      "@typescript-eslint/parser",
      "babel-plugin-istanbul",
      "browserslist",
      "eslint",
      "eslint-config-next",
      "execa",
      "jest-junit",
      "lint-staged",
      "update-browserslist-db",
      "zod",
      "zod-error"
    ]
  }
}
