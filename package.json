{
  "name": "illustry-monorepo",
  "version": "1.1.0",
  "repository": "https://github.com/mrVladimirN/Illustry-monorepo.git",
  "author": "mrVladimirN <vladimir.nitu.business@outlook.com>",
  "license": "MIT",
  "workspaces": [
    "backend",
    "frontend",
    "docs",
    "types"
  ],
  "type": "module",
  "scripts": {
    "lint": "yarn workspaces foreach -A -pt run lint",
    "lint:fix": "yarn workspaces foreach -A -pt run lint:fix",
    "version": "echo \"standard-version removed; use external release tooling\"",
    "depcheck": "yarn workspaces foreach -A -pt run depcheck",
    "test": "yarn workspaces foreach -A -pt run test",
    "prepare": "husky install",
    "postversion": "echo \"manual publish step required\"",
    "build:ts": "yarn workspaces foreach -A -pt run build:ts",
    "release": "yarn lint:fix && yarn version && git push --follow-tags origin main",
    "audit": "yarn npm audit --all --recursive --severity low --no-deprecations"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "20.4.3",
    "@commitlint/lint": "20.4.3",
    "@commitlint/load": "20.4.3",
    "@types/jest": "29.5.12",
    "@typescript-eslint/eslint-plugin": "8.50.1",
    "@typescript-eslint/parser": "8.50.1",
    "depcheck": "1.4.7",
    "eslint": "9.39.2",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.29.0",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-promise": "6.1.1",
    "husky": "8.0.3",
    "jest": "29.7.0",
    "jest-junit": "16.0.0",
    "ts-jest": "29.1.1",
    "typescript": "5.5.4"
  },
  "resolutions": {
    "@fast-csv/format": "5.0.5",
    "@fast-csv/parse": "5.0.5",
    "ajv": "8.18.0",
    "@babel/helpers": "7.28.6",
    "@babel/runtime": "7.28.6",
    "axios": "1.13.6",
    "basic-ftp": "5.2.0",
    "diff": "8.0.3",
    "fast-csv": "5.0.5",
    "form-data": "4.0.5",
    "js-yaml": "4.1.1",
    "lodash": "4.17.23",
    "mdast-util-to-hast": "13.2.1",
    "micromatch": "4.0.8",
    "qs": "6.15.0",
    "rollup": "4.59.0",
    "serialize-javascript": "7.0.4",
    "systeminformation": "5.31.3",
    "tar": "7.5.10",
    "tmp": "0.2.5",
    "vite": "7.3.1",
    "unzipper": "0.12.3"
  },
  "jest": {
    "collectCoverage": true,
    "roots": [
      "backend/",
      "frontend/",
      "types/",
      "docs/"
    ],
    "collectCoverageFrom": [
      "**/*.{js,ts}",
      "!coverage/**",
      "!**/node_modules/**",
      "!**/dist/**",
      "!**/commitlint.config.js"
    ],
    "transform": {
      ".+\\.ts$": "ts-jest"
    },
    "coverageReporters": [
      "text",
      "text-summary"
    ],
    "reporters": [
      "default"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 0,
        "functions": 0,
        "lines": 0,
        "statements": 0
      }
    },
    "testEnvironment": "node"
  },
  "packageManager": "yarn@4.5.3"
}
