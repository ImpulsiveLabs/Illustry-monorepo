{
  "name": "@impulsivelabs/illustry-client",
  "version": "0.2.0",
  "scripts": {
    "depcheck": "depcheck --ignore-bin-package --ignores='postcss,autoprefixer,@typescript-eslint/parser,zod-error,@testing-library/user-event,@vitest/coverage-v8'",
    "clean": "rm -rf ./.next",
    "start:dev": "next dev",
    "build:ts": "BACKEND_INTERNAL_URL=${BACKEND_INTERNAL_URL:-http://localhost:3001} NEXT_PUBLIC_BACKEND_PUBLIC_URL=${NEXT_PUBLIC_BACKEND_PUBLIC_URL:-http://localhost:3001} next build --webpack",
    "start:prod": "node .next/standalone/frontend/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "e2e": "playwright test",
    "e2e:coverage": "rm -rf .nyc_output coverage/e2e && BABEL_ENV=coverage PW_E2E_COVERAGE=1 E2E_COVERAGE=1 playwright test --project=chromium && nyc report --nycrc-path .nycrc.e2e.json",
    "e2e:coverage:check": "yarn e2e:coverage && nyc check-coverage --nycrc-path .nycrc.e2e.json",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@files-ui/react": "1.0.8",
    "@hookform/resolvers": "3.1.1",
    "@illustry/types": "1.0.1",
    "@monaco-editor/react": "4.7.0",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-icons": "1.3.2",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@tanstack/react-table": "8.10.7",
    "autoprefixer": "10.4.16",
    "class-variance-authority": "0.7.0",
    "clsx": "2.0.0",
    "cmdk": "0.2.0",
    "depcheck": "1.4.7",
    "dotenv": "16.3.1",
    "echarts": "5.4.3",
    "echarts-for-react": "3.0.2",
    "echarts-wordcloud": "2.1.0",
    "lint-staged": "16.3.2",
    "lucide-react": "0.292.0",
    "monaco-editor": "0.52.2",
    "next": "16.1.7",
    "next-themes": "0.2.1",
    "react": "18.3.1",
    "react-colorful": "5.6.1",
    "react-dom": "18.3.1",
    "react-grid-layout": "1.5.0",
    "react-hook-form": "7.48.2",
    "react-intersection-observer": "9.5.3",
    "react-vertical-timeline-component": "3.6.0",
    "react-virtuoso": "4.12.7",
    "react-wrap-balancer": "1.1.0",
    "sonner": "1.2.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss-animate": "1.0.7",
    "uuid": "9.0.1",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@tailwindcss/typography": "0.5.10",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/echarts": "4.9.21",
    "@types/node": "20.19.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@types/react-grid-layout": "1.3.5",
    "@types/react-vertical-timeline-component": "3.3.6",
    "@types/uuid": "9.0.7",
    "@typescript-eslint/eslint-plugin": "8.50.1",
    "@typescript-eslint/parser": "8.50.1",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "babel-plugin-istanbul": "7.0.1",
    "browserslist": "4.28.0",
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-next": "15.5.0",
    "eslint-plugin-import": "2.32.0",
    "istanbul-lib-coverage": "3.2.2",
    "jsdom": "28.1.0",
    "next-router-mock": "1.0.2",
    "nyc": "17.1.0",
    "postcss": "8.4.31",
    "tailwindcss": "3.3.5",
    "typescript": "5.9.3",
    "update-browserslist-db": "1.2.3",
    "vitest": "4.0.18",
    "zod": "3.22.4",
    "zod-error": "1.5.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "git add"
    ]
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
