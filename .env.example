# Docker Compose defaults for local development
AUTH_APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_PUBLIC_URL=http://localhost:7001
CORS_ORIGIN_ALLOWLIST=http://localhost:3000,http://127.0.0.1:3000,http://0.0.0.0:3000,http://localhost:4321,http://127.0.0.1:4321,http://0.0.0.0:4321
MONGO_URL=mongodb+srv://your_atlas_username:your_atlas_password@cluster0.example.mongodb.net/illustry?retryWrites=true&w=majority&appName=Cluster0
MONGO_DB_NAME=illustry
MONGO_USER=
MONGO_PASSWORD=
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
ALLOW_LOCAL_MONGO_PROVISIONING=0
TEST_USERS_PASSWORD=IllustryTest123!
REDIS_URL=redis://redis:6379
REDIS_REALTIME_CHANNEL=illustry:realtime
REALTIME_HEARTBEAT_INTERVAL_MS=30000
GLOBAL_RATE_LIMIT_MAX=600
SHARE_INVITE_TTL_HOURS=72

# Shared auth/email integration
EMAIL_SERVICE_API_KEY=illustry-email-service-local-key
AUTH_EMAIL_VERIFICATION_TTL_MINUTES=15
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:7001/api/auth/google/callback
GOOGLE_OAUTH_SCOPE=openid email profile

# Resend API for real email delivery in local Docker
# Note: onboarding@resend.dev is only for testing and may only deliver to your own Resend account email
# until you verify your own sending domain in Resend.
RESEND_API_KEY=re_xxxxxxxxx
RESEND_TEST_EMAIL=your-own-resend-account-email@example.com
SMTP_FROM_EMAIL=Illustry <onboarding@resend.dev>

# Local SMTP capture with Mailpit
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_EMAIL=no-reply@illustry.local

# SMTP fallback example
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM_EMAIL=Illustry <yourgmail@gmail.com>
